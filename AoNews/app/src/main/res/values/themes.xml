<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme (Light) -->
    <style name="Theme.AoNews" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorBackground">@color/light_bg</item>
        <item name="android:colorBackground">@color/light_bg</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="colorOnSurfaceVariant">#5C6B7A</item>
        <item name="colorOutlineVariant">#E0E4EA</item>
        <item name="android:statusBarColor">@color/light_surface</item>
        <item name="android:navigationBarColor">@color/light_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.AoNews.Splash" parent="Theme.AoNews">
        <item name="colorBackground">@color/splash_bg</item>
        <item name="android:colorBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@color/splash_bg</item>
        <item name="android:navigationBarColor">@color/splash_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- No Action Bar -->
    <style name="Theme.AoNews.NoActionBar" parent="Theme.AoNews">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

</resources>
